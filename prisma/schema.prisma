generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// Core User & Authentication
// ============================================

model User {
  id            String     @id @default(cuid())
  name          String?
  username      String?    @unique // Added for students (Application No)
  email         String?    @unique // Made optional for students
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          SystemRole @default(USER)
  lastSeen      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts       Account[]
  sessions       Session[]
  workspaceRoles WorkspaceRole[]
  studentProfile StudentProfile?
  notifications  Notification[]
}

enum SystemRole {
  SUPER_ADMIN
  USER
}

// ============================================
// Multi-Tenancy (Workspaces)
// ============================================

model Workspace {
  id        String  @id @default(cuid())
  name      String
  subdomain String  @unique
  logoUrl   String?
  isActive  Boolean @default(true)

  tokensBalance Int @default(0) // Custom Token Economy

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  roles           WorkspaceRole[]
  courses         Course[]
  batches         Batch[]
  studentProfiles StudentProfile[]
  attendances     Attendance[]
  invoices        Invoice[]
  siteSettings    SiteSettings?
  events          Event[]
  galleryItems    GalleryItem[]
  admissionConfig AdmissionFormConfig?
  admissionApps   AdmissionApplication[]
  notifications   Notification[]
}

// ============================================
// Site & Page Configuration
// ============================================

model SiteSettings {
  id           String  @id @default(cuid())
  workspaceId  String? @unique // null means global site settings
  siteName     String?
  logoUrl      String?
  primaryColor String?
  accentColor  String?
  fontFamily   String?

  contactEmail     String?
  contactPhone     String?
  whatsapp         String?
  address          String?
  googleMapLink    String?
  brandDescription String?
  socialLinks      Json? // { facebook, twitter, instagram, linkedin, youtube }
  pageHeaderBanner String?

  navigation   Json? // [{ label: 'Home', href: '/', isActive: true }, ...]
  navbarConfig Json? // { showNavbar, showTopBar, showMenus, ctaPrimary: {text, link}, ctaSecondary: {text, link} }

  sections LandingSection[]

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LandingSection {
  id             String  @id @default(cuid())
  siteSettingsId String
  type           String // hero, about, why-choose-us, achievements, partners, testimonials, faq, contact
  title          String?
  subtitle       String?
  content        Json? // component-specific data (e.g., slides for hero, items for achievements)
  order          Int     @default(0)
  isActive       Boolean @default(true)

  siteSettings SiteSettings @relation(fields: [siteSettingsId], references: [id], onDelete: Cascade)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @default(now()) @updatedAt

  @@unique([siteSettingsId, type])
}

// ============================================
// Role-Based Access Control
// ============================================

model WorkspaceRole {
  id          String            @id @default(cuid())
  userId      String
  workspaceId String
  role        WorkspaceRoleType @default(STAFF)

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([userId, workspaceId])
}

enum WorkspaceRoleType {
  ADMIN
  MANAGER
  STAFF
  TEACHER
  ACCOUNTANT
  STUDENT
  PARENT
}

// ============================================
// Core LMS Features (Courses & Batches)
// ============================================

model Course {
  id          String  @id @default(cuid())
  workspaceId String
  title       String
  code        String?
  description String?
  image       String? // Banner/Thumbnail URL
  feeAmount   Float   @default(0) // Standard fee amount

  category String? // e.g. "Science", "Technology"
  level    String? // e.g. "Beginner", "Advanced"
  duration String? // e.g. "6 Months"
  topics   Json? // [{ title: '...', items: ['...', '...'] }, ...]
  isActive Boolean @default(true)

  workspace     Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  batches       Batch[]
  admissionApps AdmissionApplication[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Batch {
  id          String  @id @default(cuid())
  workspaceId String
  courseId    String
  name        String // e.g., "Morning Batch A"
  schedule    String? // Could be JSON or stringified schedule

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  course    Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)

  students StudentProfile[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// Student & Parent Profiles
// ============================================

model StudentProfile {
  id          String  @id @default(cuid())
  userId      String? @unique // Optional if account isn't created yet
  workspaceId String
  batchId     String?

  fullName      String
  enrollmentNo  String // System generated ID
  dob           DateTime?
  gender        String?
  phone         String?
  email         String?
  whatsapp      String?
  parentName    String?
  parentPhone   String?
  address       String?
  bloodGroup    String?
  religion      String?
  caste         String?
  qualification Json?   // { name, year, percentage, board }
  admissionDate DateTime  @default(now())
  applicationId String?   @unique

  admissionApp AdmissionApplication? @relation(fields: [applicationId], references: [id], onDelete: SetNull)

  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  batch     Batch?    @relation(fields: [batchId], references: [id], onDelete: SetNull)

  attendances Attendance[]
  invoices    Invoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workspaceId, enrollmentNo])
}

// ============================================
// ERP / Attendance
// ============================================

model Attendance {
  id               String           @id @default(cuid())
  studentProfileId String
  workspaceId      String
  date             DateTime // The day of attendance
  status           AttendanceStatus // PRESENT, ABSENT, LATE, HALF_DAY
  remarks          String?

  student   StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  workspace Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentProfileId, date])
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
}

// ============================================
// ERP / Accounting
// ============================================

model Invoice {
  id               String @id @default(cuid())
  workspaceId      String
  studentProfileId String

  amount   Float
  status   PaymentStatus // PENDING, PAID, OVERDUE, CANCELLED
  dueDate  DateTime
  paidDate DateTime?
  notes    String? // E.g., "Monthly Tuition Fee - July"

  workspace Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  student   StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

// ============================================
// NextAuth / Auth.js Models
// ============================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Event {
  id          String   @id @default(cuid())
  workspaceId String
  title       String
  description String?  @db.Text
  date        DateTime
  time        String?
  location    String?
  image       String?
  category    String? // Topic/Category for filtering
  isFeatured  Boolean  @default(false)
  isActive    Boolean  @default(true)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GalleryItem {
  id          String  @id @default(cuid())
  workspaceId String
  title       String?
  image       String
  category    String? // e.g., Campus, Events, Sports
  isActive    Boolean @default(true)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// Student Admission System
// ============================================

model AdmissionFormConfig {
  id          String @id @default(cuid())
  workspaceId String @unique

  // JSON array of field names that are explicitly disabled. If empty/null, all default fields are enabled.
  disabledFields Json?

  // Instructions or terms to display at the beginning/end of the form
  instructions   String? @db.Text
  successMessage String? @db.Text
  
  // Dynamic Content for PDF and Portal
  declarationText String? @db.Text
  requiredDocs    Json?   // ["Aadhaar Card", "Birth Certificate", ...]

  isActive Boolean @default(true)
  enableEmailVerification Boolean @default(true)
  customFields Json? // [{ id, label, type, required, options }]

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdmissionApplication {
  id            String  @id @default(cuid())
  applicationNo String  @unique // Auto-generated human-readable ID
  workspaceId   String
  courseId      String?
  appliedCourse String? // To store the display name/fallback name

  // Step 1: Personal
  fullName     String
  guardianName String?
  dob          DateTime?
  gender       String?
  religion     String?
  caste        String?

  // Step 2: Contact & Address
  address  Json? // { vill, po, ps, dist, pin, state }
  mobile   String
  whatsapp String?
  email    String?

  // Step 3: Education
  qualification Json? // { name, year, percentage, board }

  // Custom Data (New)
  customData Json? // { fieldId: value }

  // Step 4: Documents
  photoUrl     String?
  signatureUrl String?
  idProofUrl   String?

  // System Tracking
  status          ApplicationStatus @default(PENDING)
  tempPassword    String? // For applicant portal login
  rejectionReason String?           @db.Text

  workspace      Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  course         Course?         @relation(fields: [courseId], references: [id], onDelete: SetNull)
  studentProfile StudentProfile?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

// ============================================
// Internal Notifications
// ============================================

model Notification {
  id          String  @id @default(cuid())
  workspaceId String
  userId      String? // If null, it's a broadcast to all workspace admins

  title   String
  message String  @db.Text
  type    String  @default("INFO") // INFO, SUCCESS, WARNING, ERROR, APPLICATION
  link    String? // Actionable link (e.g., /admin/students/applications/123)
  isRead  Boolean @default(false)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DocumentTemplate {
  id          String   @id @default(cuid())
  workspaceId String?  
  name        String
  type        String   
  background  String?  
  width       Int      @default(800)
  height      Int      @default(1131)
  config      Json     

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([workspaceId])
}
